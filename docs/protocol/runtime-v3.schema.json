{
  "definitions": {
    "AgentEventKind": {
      "description": "Payload of a [`RuntimeEvent::Agent`] — one step of the agent loop. Defined as transport-neutral data; the host maps its own agent events onto these.",
      "oneOf": [
        {
          "properties": {
            "kind": {
              "enum": [
                "turn_started"
              ],
              "type": "string"
            },
            "turn": {
              "format": "uint64",
              "minimum": 0.0,
              "type": "integer"
            }
          },
          "required": [
            "kind",
            "turn"
          ],
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "enum": [
                "message"
              ],
              "type": "string"
            },
            "text": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "text"
          ],
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "enum": [
                "reasoning"
              ],
              "type": "string"
            },
            "text": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "text"
          ],
          "type": "object"
        },
        {
          "properties": {
            "arguments": true,
            "kind": {
              "enum": [
                "tool_started"
              ],
              "type": "string"
            },
            "tool": {
              "type": "string"
            }
          },
          "required": [
            "arguments",
            "kind",
            "tool"
          ],
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "enum": [
                "tool_finished"
              ],
              "type": "string"
            },
            "ok": {
              "type": "boolean"
            },
            "output": {
              "type": "string"
            },
            "tool": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "ok",
            "output",
            "tool"
          ],
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "enum": [
                "interrupted"
              ],
              "type": "string"
            },
            "reason": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "reason"
          ],
          "type": "object"
        }
      ]
    },
    "RuntimeCapabilities": {
      "properties": {
        "events": {
          "$ref": "#/definitions/RuntimeEventCapabilities"
        },
        "jobs": {
          "$ref": "#/definitions/RuntimeJobCapabilities"
        },
        "transport": {
          "$ref": "#/definitions/RuntimeTransportCapabilities"
        }
      },
      "required": [
        "events",
        "jobs",
        "transport"
      ],
      "type": "object"
    },
    "RuntimeCommand": {
      "description": "Transport-neutral command understood by human-facing runtime adapters.",
      "oneOf": [
        {
          "description": "Lightweight health check used by clients before opening a real session.",
          "properties": {
            "kind": {
              "enum": [
                "ping"
              ],
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        },
        {
          "description": "Return all runtime tool specifications.",
          "properties": {
            "kind": {
              "enum": [
                "tool.list"
              ],
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        },
        {
          "description": "Execute one MCP-style tool through the runtime dispatcher.",
          "properties": {
            "arguments": {
              "additionalProperties": true,
              "default": {},
              "type": "object"
            },
            "kind": {
              "enum": [
                "tool.call"
              ],
              "type": "string"
            },
            "name": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "name"
          ],
          "type": "object"
        },
        {
          "description": "Run the built-in agent loop as a job. This is protocol vocabulary only: the host job manager (the composition root) executes it; the core runtime dispatcher does not (it has no LLM/provider knowledge). Provider/model are plain data here and translated to domain types by the host.",
          "properties": {
            "kind": {
              "enum": [
                "agent.run"
              ],
              "type": "string"
            },
            "max_turns": {
              "format": "uint32",
              "minimum": 0.0,
              "type": [
                "integer",
                "null"
              ]
            },
            "model": {
              "type": "string"
            },
            "provider": {
              "type": "string"
            },
            "reasoning_effort": {
              "type": [
                "string",
                "null"
              ]
            },
            "system_prompt": {
              "type": [
                "string",
                "null"
              ]
            },
            "task": {
              "type": "string"
            },
            "temperature": {
              "format": "float",
              "type": [
                "number",
                "null"
              ]
            },
            "tool_filter": {
              "items": {
                "type": "string"
              },
              "type": [
                "array",
                "null"
              ]
            }
          },
          "required": [
            "kind",
            "model",
            "provider",
            "task"
          ],
          "type": "object"
        },
        {
          "description": "Start or resume a host-managed interactive agent session.",
          "properties": {
            "agent": {
              "type": [
                "string",
                "null"
              ]
            },
            "kind": {
              "enum": [
                "session.start"
              ],
              "type": "string"
            },
            "max_turns": {
              "format": "uint32",
              "minimum": 0.0,
              "type": [
                "integer",
                "null"
              ]
            },
            "model": {
              "type": "string"
            },
            "provider": {
              "type": "string"
            },
            "reasoning_effort": {
              "type": [
                "string",
                "null"
              ]
            },
            "resume": {
              "type": [
                "string",
                "null"
              ]
            },
            "system_prompt": {
              "type": [
                "string",
                "null"
              ]
            },
            "temperature": {
              "format": "float",
              "type": [
                "number",
                "null"
              ]
            },
            "tool_filter": {
              "items": {
                "type": "string"
              },
              "type": [
                "array",
                "null"
              ]
            },
            "workspace": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [
            "kind",
            "model",
            "provider"
          ],
          "type": "object"
        },
        {
          "description": "Send a user message to an existing host-managed session.",
          "properties": {
            "kind": {
              "enum": [
                "session.message"
              ],
              "type": "string"
            },
            "session_id": {
              "type": "string"
            },
            "text": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "session_id",
            "text"
          ],
          "type": "object"
        },
        {
          "description": "Interrupt the current turn of an existing host-managed session.",
          "properties": {
            "kind": {
              "enum": [
                "session.interrupt"
              ],
              "type": "string"
            },
            "session_id": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "session_id"
          ],
          "type": "object"
        },
        {
          "description": "Reply to a session approval request.",
          "properties": {
            "decision": {
              "$ref": "#/definitions/SessionApprovalDecision"
            },
            "kind": {
              "enum": [
                "session.respond"
              ],
              "type": "string"
            },
            "request_id": {
              "type": "string"
            },
            "session_id": {
              "type": "string"
            }
          },
          "required": [
            "decision",
            "kind",
            "request_id",
            "session_id"
          ],
          "type": "object"
        },
        {
          "description": "Fetch one host-managed session.",
          "properties": {
            "kind": {
              "enum": [
                "session.get"
              ],
              "type": "string"
            },
            "session_id": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "session_id"
          ],
          "type": "object"
        },
        {
          "description": "List host-managed sessions.",
          "properties": {
            "kind": {
              "enum": [
                "session.list"
              ],
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        },
        {
          "description": "Close a host-managed session.",
          "properties": {
            "kind": {
              "enum": [
                "session.close"
              ],
              "type": "string"
            },
            "session_id": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "session_id"
          ],
          "type": "object"
        },
        {
          "description": "Start a host-managed OAuth login and return an authorization URL.",
          "properties": {
            "kind": {
              "enum": [
                "auth.start"
              ],
              "type": "string"
            },
            "provider": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "provider"
          ],
          "type": "object"
        },
        {
          "description": "Complete a host-managed OAuth login with a code or pasted callback URL.",
          "properties": {
            "callback_url": {
              "type": [
                "string",
                "null"
              ]
            },
            "code": {
              "type": [
                "string",
                "null"
              ]
            },
            "kind": {
              "enum": [
                "auth.complete"
              ],
              "type": "string"
            },
            "login_id": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "login_id"
          ],
          "type": "object"
        },
        {
          "description": "Return stored OAuth/API-key credential status without secrets.",
          "properties": {
            "kind": {
              "enum": [
                "auth.status"
              ],
              "type": "string"
            },
            "provider": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "provider"
          ],
          "type": "object"
        },
        {
          "description": "Remove stored credentials for a provider.",
          "properties": {
            "kind": {
              "enum": [
                "auth.logout"
              ],
              "type": "string"
            },
            "provider": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "provider"
          ],
          "type": "object"
        }
      ]
    },
    "RuntimeEvent": {
      "description": "Runtime event emitted by human-facing adapters while executing jobs.",
      "oneOf": [
        {
          "properties": {
            "command": {
              "type": "string"
            },
            "job_id": {
              "type": "string"
            },
            "tool_name": {
              "type": [
                "string",
                "null"
              ]
            },
            "type": {
              "enum": [
                "job_started"
              ],
              "type": "string"
            }
          },
          "required": [
            "command",
            "job_id",
            "type"
          ],
          "type": "object"
        },
        {
          "properties": {
            "current": {
              "format": "uint64",
              "minimum": 0.0,
              "type": [
                "integer",
                "null"
              ]
            },
            "job_id": {
              "type": "string"
            },
            "message": {
              "type": "string"
            },
            "stage": {
              "type": "string"
            },
            "total": {
              "format": "uint64",
              "minimum": 0.0,
              "type": [
                "integer",
                "null"
              ]
            },
            "type": {
              "enum": [
                "job_progress"
              ],
              "type": "string"
            }
          },
          "required": [
            "job_id",
            "message",
            "stage",
            "type"
          ],
          "type": "object"
        },
        {
          "properties": {
            "job_id": {
              "type": "string"
            },
            "type": {
              "enum": [
                "job_cancel_requested"
              ],
              "type": "string"
            }
          },
          "required": [
            "job_id",
            "type"
          ],
          "type": "object"
        },
        {
          "properties": {
            "job_id": {
              "type": "string"
            },
            "type": {
              "enum": [
                "job_completed"
              ],
              "type": "string"
            }
          },
          "required": [
            "job_id",
            "type"
          ],
          "type": "object"
        },
        {
          "properties": {
            "error": {
              "$ref": "#/definitions/RuntimeJobError"
            },
            "job_id": {
              "type": "string"
            },
            "type": {
              "enum": [
                "job_failed"
              ],
              "type": "string"
            }
          },
          "required": [
            "error",
            "job_id",
            "type"
          ],
          "type": "object"
        },
        {
          "properties": {
            "job_id": {
              "type": "string"
            },
            "type": {
              "enum": [
                "job_cancelled"
              ],
              "type": "string"
            }
          },
          "required": [
            "job_id",
            "type"
          ],
          "type": "object"
        },
        {
          "description": "A structured step from the built-in agent loop, scoped to its job.",
          "properties": {
            "event": {
              "$ref": "#/definitions/AgentEventKind"
            },
            "job_id": {
              "type": "string"
            },
            "type": {
              "enum": [
                "agent"
              ],
              "type": "string"
            }
          },
          "required": [
            "event",
            "job_id",
            "type"
          ],
          "type": "object"
        },
        {
          "description": "A host-managed session has been created or resumed.",
          "properties": {
            "session_id": {
              "type": "string"
            },
            "type": {
              "enum": [
                "session_started"
              ],
              "type": "string"
            }
          },
          "required": [
            "session_id",
            "type"
          ],
          "type": "object"
        },
        {
          "description": "A host-managed session has started processing a user turn.",
          "properties": {
            "session_id": {
              "type": "string"
            },
            "type": {
              "enum": [
                "turn_started"
              ],
              "type": "string"
            }
          },
          "required": [
            "session_id",
            "type"
          ],
          "type": "object"
        },
        {
          "description": "A host-managed session is ready for the next client action.",
          "properties": {
            "session_id": {
              "type": "string"
            },
            "type": {
              "enum": [
                "session_idle"
              ],
              "type": "string"
            }
          },
          "required": [
            "session_id",
            "type"
          ],
          "type": "object"
        },
        {
          "description": "A host-managed session has been closed.",
          "properties": {
            "session_id": {
              "type": "string"
            },
            "type": {
              "enum": [
                "session_closed"
              ],
              "type": "string"
            }
          },
          "required": [
            "session_id",
            "type"
          ],
          "type": "object"
        },
        {
          "description": "A structured agent-loop step scoped to an interactive session.",
          "properties": {
            "event": {
              "$ref": "#/definitions/AgentEventKind"
            },
            "session_id": {
              "type": "string"
            },
            "type": {
              "enum": [
                "session_agent"
              ],
              "type": "string"
            }
          },
          "required": [
            "event",
            "session_id",
            "type"
          ],
          "type": "object"
        },
        {
          "description": "A session turn needs a client/human decision before continuing.",
          "properties": {
            "arguments": true,
            "request_id": {
              "type": "string"
            },
            "session_id": {
              "type": "string"
            },
            "tool": {
              "type": "string"
            },
            "type": {
              "enum": [
                "approval_requested"
              ],
              "type": "string"
            }
          },
          "required": [
            "arguments",
            "request_id",
            "session_id",
            "tool",
            "type"
          ],
          "type": "object"
        }
      ]
    },
    "RuntimeEventCapabilities": {
      "properties": {
        "method": {
          "type": "string"
        }
      },
      "required": [
        "method"
      ],
      "type": "object"
    },
    "RuntimeInfo": {
      "properties": {
        "capabilities": {
          "$ref": "#/definitions/RuntimeCapabilities"
        },
        "protocol": {
          "type": "string"
        },
        "protocolVersion": {
          "type": "string"
        },
        "serverInfo": {
          "$ref": "#/definitions/RuntimeServerInfo"
        }
      },
      "required": [
        "capabilities",
        "protocol",
        "protocolVersion",
        "serverInfo"
      ],
      "type": "object"
    },
    "RuntimeJobCancelRequest": {
      "description": "Request payload for `runtime/jobs/cancel`.",
      "properties": {
        "job_id": {
          "type": "string"
        }
      },
      "required": [
        "job_id"
      ],
      "type": "object"
    },
    "RuntimeJobCancelResponse": {
      "properties": {
        "cancellation_requested": {
          "type": "boolean"
        },
        "job": {
          "$ref": "#/definitions/RuntimeJobSnapshot"
        }
      },
      "required": [
        "cancellation_requested",
        "job"
      ],
      "type": "object"
    },
    "RuntimeJobCapabilities": {
      "properties": {
        "commandKinds": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "methods": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "commandKinds",
        "methods"
      ],
      "type": "object"
    },
    "RuntimeJobError": {
      "description": "Structured error stored on failed runtime jobs.",
      "properties": {
        "kind": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "message"
      ],
      "type": "object"
    },
    "RuntimeJobGetRequest": {
      "description": "Request payload for `runtime/jobs/get`.",
      "properties": {
        "include_result": {
          "default": true,
          "type": "boolean"
        },
        "job_id": {
          "type": "string"
        }
      },
      "required": [
        "job_id"
      ],
      "type": "object"
    },
    "RuntimeJobListRequest": {
      "description": "Request payload for `runtime/jobs/list`.",
      "properties": {
        "include_results": {
          "default": false,
          "type": "boolean"
        },
        "include_terminal": {
          "default": true,
          "type": "boolean"
        },
        "limit": {
          "default": 100,
          "format": "uint",
          "minimum": 0.0,
          "type": "integer"
        }
      },
      "type": "object"
    },
    "RuntimeJobListResponse": {
      "properties": {
        "jobs": {
          "items": {
            "$ref": "#/definitions/RuntimeJobSnapshot"
          },
          "type": "array"
        }
      },
      "required": [
        "jobs"
      ],
      "type": "object"
    },
    "RuntimeJobResponse": {
      "properties": {
        "job": {
          "$ref": "#/definitions/RuntimeJobSnapshot"
        }
      },
      "required": [
        "job"
      ],
      "type": "object"
    },
    "RuntimeJobSnapshot": {
      "description": "Snapshot of a runtime job owned by a transport/daemon implementation.",
      "properties": {
        "cancel_requested": {
          "type": "boolean"
        },
        "command": {
          "type": "string"
        },
        "created_at_ms": {
          "format": "uint64",
          "minimum": 0.0,
          "type": "integer"
        },
        "error": {
          "anyOf": [
            {
              "$ref": "#/definitions/RuntimeJobError"
            },
            {
              "type": "null"
            }
          ]
        },
        "finished_at_ms": {
          "format": "uint64",
          "minimum": 0.0,
          "type": [
            "integer",
            "null"
          ]
        },
        "job_id": {
          "type": "string"
        },
        "result": true,
        "started_at_ms": {
          "format": "uint64",
          "minimum": 0.0,
          "type": [
            "integer",
            "null"
          ]
        },
        "status": {
          "$ref": "#/definitions/RuntimeJobStatus"
        },
        "tool_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "updated_at_ms": {
          "format": "uint64",
          "minimum": 0.0,
          "type": "integer"
        }
      },
      "required": [
        "cancel_requested",
        "command",
        "created_at_ms",
        "job_id",
        "status",
        "updated_at_ms"
      ],
      "type": "object"
    },
    "RuntimeJobStartRequest": {
      "description": "Request payload for `runtime/jobs/start`.",
      "properties": {
        "command": {
          "$ref": "#/definitions/RuntimeCommand"
        },
        "job_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "command"
      ],
      "type": "object"
    },
    "RuntimeJobStatus": {
      "description": "Status values used by daemon-owned runtime jobs.",
      "enum": [
        "running",
        "cancelling",
        "completed",
        "failed",
        "cancelled"
      ],
      "type": "string"
    },
    "RuntimeServerInfo": {
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "version"
      ],
      "type": "object"
    },
    "RuntimeToolSpec": {
      "additionalProperties": true,
      "description": "Runtime-visible tool specification shape shared with frontend clients.",
      "properties": {
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "inputSchema": true,
        "name": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "RuntimeToolsListResponse": {
      "properties": {
        "tools": {
          "items": {
            "$ref": "#/definitions/RuntimeToolSpec"
          },
          "type": "array"
        }
      },
      "required": [
        "tools"
      ],
      "type": "object"
    },
    "RuntimeTransportCapabilities": {
      "properties": {
        "framing": {
          "type": "string"
        },
        "jsonrpc": {
          "type": "string"
        }
      },
      "required": [
        "framing",
        "jsonrpc"
      ],
      "type": "object"
    },
    "SessionApprovalDecision": {
      "description": "Decision supplied by a human/client for a session approval request.",
