{
  "type": "module",
  "name": "@nerve-workstation/tui",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript TUI frontend scaffolding for Nerve runtime daemon",
  "scripts": {
    "smoke": "bun src/cli/smoke.ts",
    "chat": "bun src/cli/chat.ts",
    "build": "bun build src/cli/chat.ts --compile --outfile dist/nerve-chat",
    "test": "bun test test/*.test.ts",
    "check": "bun test test/*.test.ts && tsc --noEmit"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "bun-types": "1.3.14",
    "typescript": "6.0.3"
  }
}
