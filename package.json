{
  "name": "context-engine-rs",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "scripts": {
    "test": "bun run --parallel test:ts test:rs",
    "test:ts": "bun run --workspaces --if-present test",
    "test:rs": "cargo test --workspace",
    "check": "bun run --parallel check:ts check:rs",
    "check:ts": "bun run --workspaces --if-present check",
    "check:rs": "cargo fmt --all --check && cargo clippy --workspace --all-targets -- -D warnings",
    "tui:smoke": "bun --cwd=packages/tui run smoke -- --root ../.."
  }
}
