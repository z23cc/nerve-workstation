{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nerve Workstation",
  "version": "0.0.74",
  "identifier": "dev.nerve.workstation",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Nerve Workstation",
        "width": 1280,
        "height": 860,
        "minWidth": 720,
        "minHeight": 480,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/nerve"],
    "iOS": {
      "minimumSystemVersion": "13.0",
      "infoPlist": "Info.ios.plist"
    },
    "android": {
      "minSdkVersion": 24
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
